{
  "schema_version": 2,
  "data_contract": "prompt_control_flow/DATA_CONTRACT_REASONING_TRACES.md",
  "canonical_artifacts": {
    "same_problem_multisample_raw_hidden": {
      "path": "data/gsm8k_v2_custom.npz",
      "roles": [
        "same-problem donor fields",
        "raw token hidden-state geometry",
        "causal residual intervention pilot"
      ],
      "evidence_tier": "legacy_same_problem_trace",
      "limitations": [
        "no exact rendered generation prompt or input token axis",
        "final-answer labels only; no human first-error labels",
        "not confirmatory for online self-state or causal intervention"
      ],
      "required_keys": [
        "problem_ids",
        "sample_idx",
        "is_correct",
        "responses",
        "steps_text",
        "sv_clouds",
        "cloud_sizes",
        "cloud_layers"
      ],
      "representation_contract": {
        "intervention_state": "observer teacher-forcing replay states at layer 16",
        "source_drift_audit": "sv_clouds pooled by cloud_sizes at cloud_layers=16",
        "alignment_only": "sv_vec_step_exp",
        "forbidden_intervention_state": "legacy stored states from a different token trace, or sv_vec_step_exp because it may use a projected reasoning basis"
      }
    },
    "processbench_cross_problem_features": {
      "paths": [
        "data/features/full_gsm8k.npz",
        "data/features/full_math.npz",
        "data/features/full_omnimath.npz"
      ],
      "roles": [
        "first-error localization",
        "cross-dataset replication",
        "sparse step hidden-state geometry"
      ],
      "evidence_tier": "legacy_benchmark_observer_trace",
      "label_contract": {
        "process_label": "gold_error_step",
        "legacy_is_correct": "final_answer_correct",
        "warning": "never use legacy is_correct as a process-correct label"
      },
      "not_valid_for": [
        "same-problem donor fields",
        "exact causal replay without a separate prompt trace",
        "original solution-generator internal states"
      ]
    },
    "generation_matched_same_problem_trace": {
      "writer": "10_sample_and_extract.py",
      "evidence_tier": "generation_matched_self_trace",
      "required_keys": [
        "data_contract_version",
        "trace_semantics",
        "prompts",
        "generated_token_ids",
        "input_ids",
        "attention_mask",
        "step_token_ranges",
        "problem_ids",
        "sample_idx",
        "final_answer_correct",
        "process_correct"
      ],
      "roles": [
        "same-problem difficulty-controlled analysis",
        "generation-matched self-state geometry",
        "causal intervention after alignment gates"
      ],
      "limitations": [
        "process_correct is unknown until a separate process annotation is added"
      ]
    }
  }
}
